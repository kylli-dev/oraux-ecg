# Environnement production
# Copier en .env.prod et remplir les valeurs
# IMPORTANT : Ne jamais committer .env.prod dans Git

# PostgreSQL
POSTGRES_DB=oraux_prod
POSTGRES_USER=oraux_prod
POSTGRES_PASSWORD=GENERATE_WITH_openssl_rand_base64_32

# Backend
DATABASE_URL=postgresql://oraux_prod:POSTGRES_PASSWORD@db:5432/oraux_prod
ADMIN_API_KEY=GENERATE_WITH_openssl_rand_hex_32
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_ADMIN_API_KEY=SAME_AS_ADMIN_API_KEY

# Nginx
HTTP_PORT=80
HTTPS_PORT=443
