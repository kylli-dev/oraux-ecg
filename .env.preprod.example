# Environnement pré-production (staging)
# Copier en .env.preprod et remplir les valeurs

# PostgreSQL
POSTGRES_DB=oraux_preprod
POSTGRES_USER=oraux
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend
DATABASE_URL=postgresql://oraux:CHANGE_ME_STRONG_PASSWORD@db:5432/oraux_preprod
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Frontend (URL publique du serveur de preprod)
NEXT_PUBLIC_API_BASE_URL=http://preprod.yourdomain.com
NEXT_PUBLIC_API_URL=http://preprod.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://preprod.yourdomain.com
NEXT_PUBLIC_ADMIN_API_KEY=CHANGE_ME_SAME_AS_ADMIN_API_KEY
NEXT_PUBLIC_ENV=preprod

# Nginx
HTTP_PORT=80
